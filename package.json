{
  "name": "@vrsim/earth-engine-ol",
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/esm/index.mjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "style": "./dist/style.css",
  "files": [
    "dist"
  ],
  "workspaces": [
    "website"
  ],
  "scripts": {
    "dev": "vite",
    "demo:dev": "vite",
    "demo:dist": "npm run build && vite --mode acceptance-dist",
    "demo:build": "vite build --mode acceptance-source --outDir .test-output",
    "demo:build:dist": "vite build --mode acceptance-dist --outDir .test-output-dist",
    "demo:coverage": "vitest run test/ManualExamplesCoverage.test.ts",
    "typecheck:demo": "tsc --noEmit -p .test/tsconfig.json",
    "demo:check": "npm run typecheck:demo && npm run demo:coverage && npm run demo:build && npm run build && npm run demo:build:dist",
    "build": "npm run clean && rollup --bundleConfigAsCjs -c rollup.config.mjs --environment MODE:prod && tsc --emitDeclarationOnly --declaration --declarationDir dist/types && npm run build:styles",
    "build:styles": "sass --load-path=node_modules --style=compressed --no-source-map src/assets/style/public.scss dist/style.css",
    "clean": "rimraf -rf dist/",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.type-tests.json",
    "lint": "eslint --no-ignore \"src/**/*.ts\" \"test/**/*.ts\" \".test/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,scss}\" \"test/**/*.{ts,mjs,json,html}\" \".test/**/*.{ts,scss,json,html}\" \"scripts/**/*.mjs\" \"*.{json,md,ts,mjs}\"",
    "format:check": "node scripts/check-prettier-baseline.mjs && prettier --check --ignore-path .prettierignore \"src/**/*.{ts,scss}\" \"test/**/*.{ts,mjs,json,html}\" \".test/**/*.{ts,scss,json,html}\" \"scripts/**/*.mjs\" \"*.{json,md,ts,mjs}\"",
    "verify": "npm run typecheck && npm run lint && npm run build && npm test",
    "verify:code": "npm run typecheck && npm run typecheck:demo && npm run lint && npm run format:check && npm run build && npm run demo:build && npm run demo:build:dist && npm run test:code && npm run test:browser && npm run test:package",
    "prepack": "npm run build",
    "doc": "typedoc --options ./typedoc.json",
    "api:sync": "npm run doc && node scripts/docs/api-docs.mjs",
    "api:check": "node scripts/docs/check-api-coverage.mjs",
    "docs:dev": "npm run build && npm run api:sync && npm run dev --workspace=ol-doc",
    "docs:build": "npm run build && npm run api:sync && npm run api:check && npm run build --workspace=ol-doc",
    "pack:offline": "npm pack",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:code": "vitest run --config vitest.code.config.ts",
    "test:package": "npm run build && vitest run test/PackageExports.test.ts && node scripts/package/assert-package-contract.mjs && node scripts/package/test-offline-install.mjs",
    "test:watch": "vitest"
  },
  "author": "gkc",
  "peerDependencies": {
    "ol": "^10.9.0"
  },
  "peerDependenciesMeta": {
    "ol": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@rollup/plugin-commonjs": "^24.0.1",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/plugin-url": "^8.0.2",
    "@types/node": "^18.13.0",
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "eslint": "^8.34.0",
    "ol": "10.9.0",
    "prettier": "^3.9.5",
    "rimraf": "^4.1.2",
    "rollup": "^3.15.0",
    "sass": "^1.58.1",
    "tslib": "^2.5.0",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "5.9.3",
    "vite": "^4.1.1",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "./dist/style.css"
  ]
}
