{
  "name": "@vrsim/earth-engine-ol",
  "version": "1.0.3",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": [
    "website"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && rollup --bundleConfigAsCjs -c rollup.config.mjs --environment MODE:prod && tsc --emitDeclarationOnly --declaration --declarationDir dist/types",
    "clean": "rimraf -rf dist/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,scss}\" \"test/**/*.ts\" \"*.{json,md,ts,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss}\" \"test/**/*.ts\" \"*.{json,md,ts,mjs}\"",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "prepack": "npm run build",
    "copy": "copyfiles -u 1 src/**/*.glsl earth-engine",
    "tsc": "npm run clean && tsc && npm run copy",
    "doc": "typedoc --options ./typedoc.json",
    "docs:dev": "npm run build && npm run dev --workspace=ol-doc",
    "docs:build": "npm run build && npm run doc && npm run build --workspace=ol-doc",
    "pack:offline": "npm pack",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "gkc",
  "dependencies": {
    "heatmap.js": "^2.0.5",
    "lodash": "^4.17.21",
    "mitt": "^3.0.0",
    "ol-wind": "^1.1.2"
  },
  "peerDependencies": {
    "ol": "^7.5.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.1",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/plugin-url": "^8.0.2",
    "@types/heatmap.js": "^2.0.37",
    "@types/lodash": "^4.17.20",
    "@types/node": "^18.13.0",
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.34.0",
    "ol": "^7.5.2",
    "prettier": "^3.9.5",
    "rimraf": "^4.1.2",
    "rollup": "^3.15.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-shader": "^0.0.3",
    "sass": "^1.58.1",
    "tslib": "^2.5.0",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "5.4",
    "vite": "^4.1.1",
    "vite-plugin-string": "^1.2.1",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": [
    "dist/index.css",
    "dist/index.es.css",
    "dist/index.cjs.css"
  ]
}
