{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "declaration": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "exclude": [
    "vite.config.ts",
    "playwright.config.ts",
    "playwright.docs.config.ts",
    "playwright.performance.config.ts",
    "vitest.config.ts",
    "vitest.code.config.ts",
    "rollup.config.mjs",
    "typedoc.json",
    "dist",
    "node_modules",
    ".test",
    "test",
    "website"
  ]
}
